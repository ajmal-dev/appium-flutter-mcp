# Appium server
APPIUM_URL=http://127.0.0.1:4723

# Platform: ios or android
PLATFORM=ios

# Optional: attach to existing Appium session instead of creating a new one
# SESSION_ID=

# Optional: path to your Flutter app source (for ValueKey discovery /
# source-aware locators). Should be the package root containing pubspec.yaml + lib/.
# FLUTTER_APP_PATH=/path/to/your/flutter/app

# Optional: path to a directory of shared Flutter component packages
# (each subdirectory should be a pub package with its own pubspec.yaml + lib/).
# FLUTTER_COMPONENTS_PATH=/path/to/your/flutter/components

# Optional: directory holding CUA-mode .cua.md test files. When set, cua_run_test
# will resolve relative filenames against this directory before falling back to cwd.
# CUA_TESTCASES_DIR=/path/to/your/cua/testcases

# Appium device / app capabilities (configure per device + app)
# APPIUM_UDID=
# APPIUM_BUNDLE_ID=
# APPIUM_APP_PACKAGE=
# APPIUM_APP_ACTIVITY=
# APPIUM_DEVICE_NAME=
# APPIUM_PLATFORM_VERSION=
# APPIUM_APP_PATH=
# APPIUM_NO_RESET=true
# APPIUM_FULL_RESET=false
# APPIUM_SHOULD_TERMINATE_APP=false

# Dart VM Service settings (used for fast Flutter operations).
# When VM_AUTO_DISCOVER is true (default) and VM_SERVICE_URL is empty,
# the MCP scans running Flutter processes for the VM URL.
# VM_SERVICE_URL=ws://127.0.0.1:PORT/ws
# VM_AUTO_DISCOVER=true

# Flutter driver settings
FLUTTER_SERVER_LAUNCH_TIMEOUT=10000
FLUTTER_SYSTEM_PORT=10001
FLUTTER_ELEMENT_WAIT_TIMEOUT=5000
FLUTTER_SCROLL_MAX_ITERATION=15
FLUTTER_SCROLL_DELTA=64

# Tree settings
TREE_CACHE_TTL_MS=5000
SCREENSHOT_ON_ACTION=true

# Logging
LOG_LEVEL=info
